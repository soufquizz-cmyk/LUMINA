VITE_PROXY_PREFIX=/proxy
# Vite dev proxy → Nodecast (ms). Long media uses XTREAM_PROXY_UPSTREAM_MS (default 120000). POST /api/transcode/session uses the smaller of that and XTREAM_PROXY_TRANSCODE_SESSION_MS (default 18000) so a broken transcode fails fast.
# XTREAM_PROXY_UPSTREAM_MS=
# XTREAM_PROXY_TRANSCODE_SESSION_MS=
# GET /api/proxy/stream with header X-Playable-Probe: 1 (catalog probe only; not video playback).
# XTREAM_PROXY_STREAM_PROBE_MS=

# Pays sélectionné au premier chargement (sans valeur en session). Id exact (`country_france`) ou nom (`France`).
VITE_DEFAULT_COUNTRY=

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Admin UI : par défaut off. Activer avec ?admin=1 sur l’URL du lecteur (session onglet), désactiver avec ?admin=0.

VITE_ASSIGNMENT_EXACT_MATCH_ONLY=

VITE_NODECAST_URL=
VITE_NODECAST_USERNAME=
VITE_NODECAST_PASSWORD=
# Si `get_series` est vide : charge `{VITE_NODECAST_URL}/api/favorites?itemType=series`. Sinon URL absolue ou chemin (/api/...).
VITE_NODECAST_SERIES_FAVORITES_URL=

# Covers: Worker URL + secret below, or VITE_R2_COVER_UPLOAD=1 with R2_* (server only); else Supabase Storage.
VITE_CLOUDFLARE_COVER_UPLOAD_URL=
VITE_CLOUDFLARE_COVER_UPLOAD_SECRET=
VITE_R2_COVER_UPLOAD=
# Real 32-char hex Account ID from Cloudflare dashboard (never the literal name R2_ACCOUNT_ID).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# S3 API origin (no trailing slash). Default: https://<R2_ACCOUNT_ID>.r2.cloudflarestorage.com
# If the bucket is EU (or other) jurisdiction, use R2_JURISDICTION or set R2_S3_ENDPOINT explicitly (see Cloudflare R2 → Authentication).
R2_JURISDICTION=
R2_S3_ENDPOINT=
# Public origin (no trailing slash), from R2 → bucket → Settings → Public development URL — e.g. https://pub-….r2.dev
# Unset → https://<R2_BUCKET_NAME>.r2.dev (never use https://<bucket>.<account_id>.r2.dev — invalid TLS).
R2_PUBLIC_BASE_URL=

# Browser console + terminal (Vite): package cover upload + grid image diagnostics
VITE_DEBUG_PACKAGE_COVER=

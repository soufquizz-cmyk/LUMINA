{
  "name": "xtream-code-player",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "seed:countries": "node scripts/seed-canonical-countries.mjs",
    "build:seed-sql": "node scripts/build-canonical-countries-seed-sql.mjs",
    "build": "tsc && vite build",
    "build:namecheap": "cross-env VITE_PROXY_PREFIX=/proxy.php tsc && vite build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.0",
    "@types/busboy": "^1.5.4",
    "@types/node": "^25.6.0",
    "cross-env": "^7.0.3",
    "typescript": "~5.6.3",
    "vite": "^6.0.1",
    "wrangler": "^4.88.0"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1041.0",
    "@smithy/node-http-handler": "^4.6.1",
    "@supabase/supabase-js": "^2.49.1",
    "@upstash/redis": "^1.38.0",
    "@vercel/node": "^5.0.0",
    "busboy": "^1.6.0",
    "hls.js": "^1.5.7"
  }
}

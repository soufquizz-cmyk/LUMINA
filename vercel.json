{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/proxy", "destination": "/api/proxy" }
  ],
  "functions": {
    "api/proxy.ts": {
      "maxDuration": 60
    },
    "api/r2-package-cover.ts": {
      "maxDuration": 30
    },
    "api/trial-status.ts": {
      "maxDuration": 10
    },
    "api/trial-increment.ts": {
      "maxDuration": 10
    },
    "api/trial.ts": {
      "maxDuration": 15
    }
  }
}
